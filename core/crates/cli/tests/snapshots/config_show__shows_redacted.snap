---
source: crates/cli/tests/config_show.rs
assertion_line: 27
expression: stdout
---
[server]
bind = "127.0.0.1:7878"
allow_remote = false

[caddy]
connect_timeout_seconds = 10
apply_timeout_seconds = 60

[caddy.admin_endpoint]
transport = "unix"
path = "/run/caddy/admin.sock"

[storage]
data_dir = "/tmp/trilithon-cs-test"
wal_checkpoint_pages = 1000

[secrets.master_key_backend]
backend = "keychain"

[concurrency]
rebase_token_ttl_minutes = 30

[tracing]
log_filter = "info,trilithon=info"
format = "pretty"

[bootstrap]
enabled_on_first_run = true
credentials_file = "***"
